@inject OakERP.Common.Abstractions.IPlatformService Platform

@if (Platform.IsWeb)
{
    <FluentToastProvider MaxToastCount="@MaxToastCount"
                         Position="@Position"
                         RemoveToastsOnNavigation="@RemoveToastsOnNavigation"
                         @rendermode="InteractiveServer"
                         Timeout="@Timeout" />
}
else
{
    <FluentToastProvider MaxToastCount="@MaxToastCount"
                         Position="@Position"
                         RemoveToastsOnNavigation="@RemoveToastsOnNavigation"
                         Timeout="@Timeout" />
}

@code
{
    [Parameter] public int MaxToastCount { get; set; } = 4;
    [Parameter] public ToastPosition Position { get; set; } = ToastPosition.BottomRight;
    [Parameter] public bool RemoveToastsOnNavigation { get; set; } = true;
    [Parameter] public int Timeout { get; set; } = 7000;
}
