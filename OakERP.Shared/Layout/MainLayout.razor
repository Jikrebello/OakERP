@inherits LayoutComponentBase
@inject ICurrentUserService CurrentUser;
@inject NavigationManager Navigation;


@if (!hasBootstrapped)
{
    <div class="centered-auth-container">
        <p>Loading...</p>
    </div>
}

else if (isAuthenticated)
{
    <FluentLayout>
        <FluentHeader>
            OakERP
        </FluentHeader>
        <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
            <NavMenu />
            <FluentBodyContent Class="body-content">
                <div class="content">
                    @Body
                </div>
            </FluentBodyContent>
        </FluentStack>
    </FluentLayout>
}
else
{
    <div class="centered-auth-container">
        @Body
    </div>
}

<OakToastProvider Position="ToastPosition.BottomRight" RemoveToastsOnNavigation="true" />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool isAuthenticated = false;
    private bool hasBootstrapped = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasBootstrapped)
        {
            try
            {
                isAuthenticated = await CurrentUser.IsAuthenticatedAsync();
                var isAtLogin = Navigation.Uri.Contains("/auth/login");

                if (!isAuthenticated && !isAtLogin)
                {
                    Navigation.NavigateTo("/auth/login", forceLoad: true);
                }
            }
            catch
            {
                // Optionally log or swallow
            }

            hasBootstrapped = true;
            StateHasChanged(); // Trigger render
        }
    }
}
