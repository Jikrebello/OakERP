@inherits LayoutComponentBase
@inject NavigationManager Navigation;
@inject IAuthSessionManager Session


@if (!hasBootstrapped)
{
    <div class="centered-auth-container">
        <p>Loading...</p>
    </div>
}
else if (isAuthenticated)
{
    <FluentLayout>
        <FluentHeader>
            OakERP
        </FluentHeader>
        <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
            <NavMenu />
            <FluentBodyContent Class="body-content">
                <div class="content">
                    @Body
                </div>
            </FluentBodyContent>
        </FluentStack>
    </FluentLayout>
}
else
{
    <div class="centered-auth-container">
        @Body
    </div>
}

<OakToastProvider Position="ToastPosition.BottomRight" RemoveToastsOnNavigation="true" />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool isAuthenticated = false;
    private bool hasBootstrapped = false;
    private bool shouldRedirectToLogin = false;

    protected override async Task OnInitializedAsync()
    {
        isAuthenticated = await Session.IsAuthenticatedAsync();

        Session.OnUserChanged += async () =>
        {
            isAuthenticated = await Session.IsAuthenticatedAsync();

            if (!isAuthenticated && !Navigation.IsOnPublicRoute("auth/login", "auth/register"))
            {
                Navigation.NavigateTo("/auth/login");
            }

            if (isAuthenticated && Navigation.IsOnPublicRoute("auth/login", "auth/register"))
            {
                Navigation.NavigateTo("/");
            }

            StateHasChanged();
        };

        if (!isAuthenticated && !Navigation.IsOnPublicRoute("auth/login", "auth/register"))
        {
            shouldRedirectToLogin = true;
        }

        hasBootstrapped = true;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (shouldRedirectToLogin)
        {
            shouldRedirectToLogin = false;
            Navigation.NavigateTo("/auth/login", forceLoad: true);
        }
    }
}



