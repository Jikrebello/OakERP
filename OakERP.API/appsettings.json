{
  "AllowedHosts": "*",
  "RunSeedOnStartup": false,
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7094" ]
  },
  "Seed": {
    "AdminEmail": "admin@oak.local",
    "AdminPassword": "admin123"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Seq": {
      "Enabled": false,
      "ServerUrl": "",
      "ApiKey": ""
    }
  },
  "RuntimeSupport": {
    "RateLimiting": {
      "Auth": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "RequestTimeouts": {
      "ControllerSeconds": 30
    }
  }
}
